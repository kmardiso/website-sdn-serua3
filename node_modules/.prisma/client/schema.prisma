generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Berita {
  id          Int             @id @default(autoincrement())
  judul       String          @db.VarChar(255)
  slug        String          @unique @db.VarChar(255)
  konten      String          @db.LongText
  ringkasan   String          @db.Text
  gambar      String?         @db.VarChar(500)
  kategori    KategoriBerita
  status      StatusPublikasi @default(DRAFT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  publishedAt DateTime?

  @@map("berita")
}

model ProfilSekolah {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  judul     String   @db.VarChar(255)
  konten    String   @db.LongText
  updatedAt DateTime @updatedAt

  @@map("profil_sekolah")
}

model Guru {
  id      Int     @id @default(autoincrement())
  nama    String  @db.VarChar(255)
  nip     String? @db.VarChar(50)
  jabatan String  @db.VarChar(255)
  mapel   String? @db.VarChar(255)
  foto    String? @db.VarChar(500)
  urutan  Int     @default(0)
  aktif   Boolean @default(true)

  @@map("guru")
}

model Fasilitas {
  id        Int     @id @default(autoincrement())
  nama      String  @db.VarChar(255)
  deskripsi String  @db.Text
  icon      String? @db.VarChar(100)
  gambar    String? @db.VarChar(500)
  urutan    Int     @default(0)

  @@map("fasilitas")
}

model Galeri {
  id        Int      @id @default(autoincrement())
  judul     String   @db.VarChar(255)
  gambar    String   @db.VarChar(500)
  kategori  String?  @db.VarChar(100)
  createdAt DateTime @default(now())

  @@map("galeri")
}

model Prestasi {
  id      Int    @id @default(autoincrement())
  judul   String @db.VarChar(255)
  tingkat String @db.VarChar(100)
  tahun   Int
  juara   String @db.VarChar(100)
  siswa   String @db.VarChar(255)

  @@map("prestasi")
}

model Kontak {
  id        Int          @id @default(autoincrement())
  nama      String       @db.VarChar(255)
  email     String       @db.VarChar(255)
  telepon   String?      @db.VarChar(50)
  pesan     String       @db.Text
  status    StatusKontak @default(BELUM_DIBACA)
  createdAt DateTime     @default(now())

  @@map("kontak")
}

model PPDB {
  id               Int          @id @default(autoincrement())
  namaLengkap      String       @db.VarChar(255)
  tempatLahir      String       @db.VarChar(100)
  tanggalLahir     DateTime
  jenisKelamin     JenisKelamin
  alamat           String       @db.Text
  namaAyah         String       @db.VarChar(255)
  namaIbu          String       @db.VarChar(255)
  teleponOrtu      String       @db.VarChar(50)
  emailOrtu        String       @db.VarChar(255)
  asalSekolah      String?      @db.VarChar(255)
  dokumenAkta      String?      @db.VarChar(500)
  dokumenKK        String?      @db.VarChar(500)
  dokumenFoto      String?      @db.VarChar(500)
  status           StatusPPDB   @default(PENDING)
  nomorPendaftaran String?      @unique @db.VarChar(50)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("ppdb")
}

model Admin {
  id        Int       @id @default(autoincrement())
  nama      String    @db.VarChar(255)
  email     String    @unique @db.VarChar(255)
  password  String    @db.VarChar(500)
  role      RoleAdmin @default(EDITOR)
  createdAt DateTime  @default(now())

  @@map("admin")
}

model InfoSekolah {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(100)
  value String @db.Text
  label String @db.VarChar(255)

  @@map("info_sekolah")
}

enum KategoriBerita {
  PENGUMUMAN
  PRESTASI
  KEGIATAN
  INFORMASI
}

enum StatusPublikasi {
  DRAFT
  PUBLISHED
}

enum StatusKontak {
  BELUM_DIBACA
  SUDAH_DIBACA
  DIBALAS
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusPPDB {
  PENDING
  DITERIMA
  DITOLAK
  WAWANCARA
}

enum RoleAdmin {
  SUPERADMIN
  EDITOR
}
