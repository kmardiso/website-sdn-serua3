generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Berita {
  id          Int             @id @default(autoincrement())
  judul       String
  slug        String          @unique
  konten      String
  ringkasan   String
  gambar      String?
  kategori    KategoriBerita
  status      StatusPublikasi @default(DRAFT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  publishedAt DateTime?

  @@map("berita")
}

model ProfilSekolah {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  judul     String
  konten    String
  updatedAt DateTime @updatedAt

  @@map("profil_sekolah")
}

model Guru {
  id      Int     @id @default(autoincrement())
  nama    String
  nip     String?
  jabatan String
  mapel   String?
  foto    String?
  urutan  Int     @default(0)
  aktif   Boolean @default(true)

  @@map("guru")
}

model Fasilitas {
  id        Int     @id @default(autoincrement())
  nama      String
  deskripsi String
  icon      String?
  gambar    String?
  urutan    Int     @default(0)

  @@map("fasilitas")
}

model Galeri {
  id        Int      @id @default(autoincrement())
  judul     String
  gambar    String
  kategori  String?
  createdAt DateTime @default(now())

  @@map("galeri")
}

model Prestasi {
  id      Int    @id @default(autoincrement())
  judul   String
  tingkat String
  tahun   Int
  juara   String
  siswa   String

  @@map("prestasi")
}

model Kontak {
  id        Int          @id @default(autoincrement())
  nama      String
  email     String
  telepon   String?
  pesan     String
  status    StatusKontak @default(BELUM_DIBACA)
  createdAt DateTime     @default(now())

  @@map("kontak")
}

model PPDB {
  id               Int          @id @default(autoincrement())
  namaLengkap      String
  tempatLahir      String
  tanggalLahir     DateTime
  jenisKelamin     JenisKelamin
  alamat           String
  namaAyah         String
  namaIbu          String
  teleponOrtu      String
  emailOrtu        String
  asalSekolah      String?
  dokumenAkta      String?
  dokumenKK        String?
  dokumenFoto      String?
  status           StatusPPDB   @default(PENDING)
  nomorPendaftaran String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("ppdb")
}

model Admin {
  id        Int       @id @default(autoincrement())
  nama      String
  email     String    @unique
  password  String
  role      RoleAdmin @default(EDITOR)
  createdAt DateTime  @default(now())

  @@map("admin")
}

model InfoSekolah {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
  label String

  @@map("info_sekolah")
}

enum KategoriBerita {
  PENGUMUMAN
  PRESTASI
  KEGIATAN
  INFORMASI
}

enum StatusPublikasi {
  DRAFT
  PUBLISHED
}

enum StatusKontak {
  BELUM_DIBACA
  SUDAH_DIBACA
  DIBALAS
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusPPDB {
  PENDING
  DITERIMA
  DITOLAK
  WAWANCARA
}

enum RoleAdmin {
  SUPERADMIN
  EDITOR
}
